<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect /public/ URLs back to root
    RewriteCond %{THE_REQUEST} /public/ [NC]
    RewriteRule ^public/(.*)$ /$1 [L,R=301]

    # Rewrite all requests to public/
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
